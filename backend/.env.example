# ╔══════════════════════════════════════════════════════════════╗
# ║         StadiumSaathi — Environment Variables                ║
# ║  Copy this file to .env and fill in your real values.        ║
# ║  NEVER commit .env to version control.                       ║
# ╚══════════════════════════════════════════════════════════════╝

# ── 1. GEMINI AI (Required for AI chat) ──────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Free tier: 60 requests/min on gemini-2.0-flash
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_KEY_HERE

# ── 2. FIREBASE ADMIN SDK (Required for live data) ───────────
# Get from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON

# Option A — Service account JSON file path (local dev)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option B — Individual env vars (Cloud Run / production)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── 3. GOOGLE CLOUD TTS (Optional — enables Neural voices) ───
# Get from: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Enable API → Credentials → Create API Key
# Free tier: 1M characters/month for WaveNet, 1M for Neural2
GOOGLE_TTS_API_KEY=AIzaSy_YOUR_TTS_KEY_HERE

# ── 4. GOOGLE MAPS (Optional — for real routing) ─────────────
# Get from: https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
# Enable: Maps JavaScript API + Routes API + Places API
GOOGLE_MAPS_API_KEY=AIzaSy_YOUR_MAPS_KEY_HERE

# ── 5. SERVER CONFIG ──────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── 6. CORS — allowed frontend origins ───────────────────────
# Add your deployed frontend URL here when going live
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500,https://your-frontend-domain.web.app

# ── 7. CLOUD RUN (auto-injected when deployed) ───────────────
# These are set automatically by Cloud Run — do not set manually
# PORT=8080  (auto)
# K_SERVICE=stadiumsaathi-backend  (auto)
# K_REVISION=stadiumsaathi-backend-00001  (auto)
